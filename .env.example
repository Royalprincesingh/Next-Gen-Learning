# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================
# REQUIRED environment variables for NeuraLrn Dashboard
#
# SETUP INSTRUCTIONS:
# 1. Visit https://supabase.com and create a new project
# 2. Copy your Project URL and Anon Key
# 3. Run: cp .env.example .env.local
# 4. Update the values below
# 5. Run schema-v2.sql in Supabase SQL Editor
# 6. npm install && npm run dev
# 4. Navigate to Settings > API (left sidebar)
# 5. Copy your Project URL and paste below
# 6. Copy your "anon public" key and paste below
# 7. Save this file as .env.local (DO NOT COMMIT .env.local)
#
# DATABASE SETUP:
# 1. Go to SQL Editor in Supabase dashboard
# 2. Create a new query
# 3. Paste the contents of src/db/schema.sql
# 4. Run the query to create the courses table and seed sample data
# ============================================================================

# Your Supabase project URL (e.g., https://xxxxxxxxxxxxx.supabase.co)
# ⚠️  PUBLIC - Safe to expose in client-side code
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anonymous public API key
# ⚠️  PUBLIC - This key can only perform read operations on public tables
# ⚠️  Make sure RLS policies are configured on your Supabase tables
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: Supabase service role key (for admin operations)
# ⚠️  PRIVATE - NEVER expose this in client-side code or commit to git
# Only use this in server-side code (.env.local only, never .env.example)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
